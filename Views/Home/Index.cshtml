@{
    ViewData["Title"] = "Forza Horizon Warzone";
}

<!-- HERO SECTION -->
<section class="hero">
    <div class="hero-video">
        <iframe src="https://www.youtube.com/embed/FYH9n37B7Yw?autoplay=1&mute=1&loop=1&playlist=FYH9n37B7Yw"
                title="Forza Horizon Bookings"
                allowfullscreen>
        </iframe>
    </div>
    <div class="hero-content">
        <h1>FROZA HORIZON WARZONE</h1>
        <p>The Ultimate Car Booking Experience</p>
        <a asp-controller="Ride" asp-action="BookRide" class="buy-btn">Start Booking</a>
    </div>
</section>

<!-- CAR SHOWCASE -->
<section class="gallery">
    <h2>Featured Cars</h2>
    <div class="grid">
        <div class="car-card">
            <img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?w=400" alt="Lamborghini">
            <h3>Lamborghini</h3>
        </div>
        <div class="car-card">
            <img src="https://images.unsplash.com/photo-1493238792000-8113da705763?w=400" alt="Nissan GTR">
            <h3>Nissan GTR</h3>
        </div>
        <div class="car-card">
            <img src="https://images.unsplash.com/photo-1511919884226-fd3cad34687c?w=400" alt="Bugatti Chiron">
            <h3>Bugatti Chiron</h3>
        </div>
        <div class="car-card">
            <img src="https://images.unsplash.com/photo-1502877338535-766e1452684a?w=400" alt="McLaren P1">
            <h3>McLaren P1</h3>
        </div>
    </div>
</section>

<!-- REVIEWS -->
<section class="reviews">
    <h2>Player Reviews</h2>
    <div class="review-grid">
        <div class="review-card">
            <p class="stars">★★★★★</p>
            <p>Best racing experience ever created.</p>
        </div>
        <div class="review-card">
            <p class="stars">★★★★☆</p>
            <p>Beautiful open world and amazing cars.</p>
        </div>
        <div class="review-card">
            <p class="stars">★★★★★</p>
            <p>Insane graphics and gameplay.</p>
        </div>
    </div>
</section>
