@model IEnumerable<GIT_Practice.Models.RideBooking>

    <!DOCTYPE html>
    <html>
    <head>

        <title>Admin Dashboard</title>

        <style>

            body {
                font-family: Segoe UI;
                background: #0f172a;
                color: white;
                margin: 0;
                padding: 40px;
            }

            h1 {
                text-align: center;
                margin-bottom: 30px;
                color: #f97316;
            }

            table {
                width: 80%;
                margin: auto;
                border-collapse: collapse;
                background: #1e293b;
                box-shadow: 0 0 15px rgba(0,0,0,0.5);
            }

            th, td {
                padding: 12px;
                text-align: center;
                border-bottom: 1px solid #334155;
            }

            th {
                background: #f97316;
                color: white;
            }

            tr:hover {
                background: #334155;
            }
        </style>

    </head>

    <body>

        <h1>🚗 Ride Bookings</h1>

        <table>

            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Car</th>
                <th>Date</th>
            </tr>

            @foreach (var ride in Model)
{
            <tr>
                <td>@ride.Name</td>
                <td>@ride.Email</td>
                <td>@ride.Car</td>
                <td>@ride.RideDate.ToShortDateString()</td>
            </tr>
}

        </table>

    </body>
</html>
